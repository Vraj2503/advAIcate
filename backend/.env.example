# Supabase URL for backend connection
SUPABASE_URL=

# Supabase Anon Key for client-side/anonymous access
SUPABASE_ANON_KEY=

# Supabase Service Role Key for backend admin operations
SUPABASE_SERVICE_ROLE_KEY=

# Groq API Key for LLM services
GROQ_API_KEY=

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=

# Set to 1 to force offline use of Transformers models
TRANSFORMERS_OFFLINE=

# Set to 1 to disable Hugging Face Hub network calls
HF_HUB_OFFLINE=

# Local path to the pre-downloaded embedding model directory
EMBEDDING_MODEL_PATH=
