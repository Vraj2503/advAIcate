# Note for Vercel Deployment:
# Most of these variables will need to be configured in your Vercel project settings
# under Settings -> Environment Variables.

# Supabase URL for client-side access
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Anon Key for client-side access
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL for the backend API (e.g. your Cloud Run URL: https://advaicate-backend-xxxxx.run.app)
# This is used by next.config.ts to proxy /api/* requests, avoiding CORS issues.
NEXT_PUBLIC_API_URL=

# Supabase Service Role Key for server-side Next.js API routes (NEVER prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth base URL (e.g., https://yourdomain.com for production)
NEXTAUTH_URL=

# NextAuth secret used to encrypt session data
NEXTAUTH_SECRET=

# Google OAuth Client ID
GOOGLE_CLIENT_ID=

# Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=
